# Primary production URL for canonical tags, sitemap, robots, and metadata.
# Set this to the final custom domain before public launch.
NEXT_PUBLIC_SITE_URL=https://www.your-domain.com

# Public contact email shown on the contact page and footer.
# Set this before launch so users, partners, and legal contacts have a real inbox.
NEXT_PUBLIC_CONTACT_EMAIL=hello@your-domain.com

# Contact form email delivery
# Required for the /contact form backend route.
CONTACT_SMTP_HOST=smtp.your-email-provider.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=hello@your-domain.com
CONTACT_SMTP_PASS=your_smtp_password_here
CONTACT_FROM_EMAIL=hello@your-domain.com
CONTACT_FROM_NAME=Toolbox Hub

# Website Speed Test
# Mobile Friendly Checker
# Optional, but strongly recommended for stable PageSpeed access.
PAGESPEED_API_KEY=your_pagespeed_api_key_here

# PDF OCR
# Required to publicly launch the PDF OCR workflow.
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# Background Remover
# Required to publicly launch background removal.
i waREMOVE_BG_API_KEY=your_remove_bg_api_key_here

# Currency Converter
# Optional provider keys. If neither is set, the app falls back to Frankfurter.
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
OPEN_EXCHANGE_RATES_APP_ID=your_open_exchange_rates_app_id_here

# Durable API rate limiting for serverless deployments
# Required in production for app/api/tools rate limiting.
# Supports Upstash Redis REST directly or Vercel KV-compatible REST credentials.
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
# Optional aliases if you use Vercel KV-style env names instead:
# KV_REST_API_URL=https://your-redis-endpoint.upstash.io
# KV_REST_API_TOKEN=your_upstash_redis_rest_token_here

# Website Screenshot Tool
# Required to publicly launch website screenshots.
# Example service contract:
#   GET {SCREENSHOT_SERVICE_URL}?url=https://example.com
# and returns an image response.
SCREENSHOT_SERVICE_URL=https://your-screenshot-service.example.com/capture
SCREENSHOT_SERVICE_AUTH_HEADER=X-Api-Key
SCREENSHOT_SERVICE_API_KEY=your_screenshot_service_api_key_here

# Protect PDF
# Required to publicly launch PDF password protection.
# Example: https://your-service.example.com/protect-pdf
PDF_PROTECT_SERVICE_URL=https://your-pdf-service.example.com/protect
PDF_PROTECT_SERVICE_AUTH_HEADER=X-Api-Key
PDF_PROTECT_SERVICE_API_KEY=your_pdf_service_api_key_here

# Observability
# Optional webhook for structured server-side tool error events.
# Leave unset to keep logging local to the server console only.
OBSERVABILITY_WEBHOOK_URL=https://your-monitoring-endpoint.example.com/tool-errors
OBSERVABILITY_WEBHOOK_AUTH_HEADER=X-Webhook-Token
OBSERVABILITY_WEBHOOK_AUTH_TOKEN=your_observability_webhook_token_here

# Client Analytics Hook
# Set to "none" until a real lightweight provider is chosen.
NEXT_PUBLIC_ANALYTICS_PROVIDER=none
